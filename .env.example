# Meta / WhatsApp Cloud API
META_WA_TOKEN='<paste-permanent-system-user-token>'
META_WA_PHONE_NUMBER_ID='<phone-number-id-from-meta>'
META_WA_BUSINESS_ACCOUNT_ID='<waba-id-from-meta>'
META_WEBHOOK_VERIFY_TOKEN='<pick-any-32-char-random-string>'
META_APP_SECRET='<meta-app-basic-settings-app-secret>'

# Anthropic
ANTHROPIC_API_KEY='<sk-ant-...>'
ANTHROPIC_MODEL='claude-haiku-4-5'

# Access control — comma-separated, no + prefix
ALLOWED_WHATSAPP_NUMBERS='1XXXXXXXXXX,91XXXXXXXXXX'
ADMIN_WHATSAPP_NUMBERS='1XXXXXXXXXX'

# Optional — bridge listen port (default 3000)
# PORT=3000
